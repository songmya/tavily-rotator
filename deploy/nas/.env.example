# ========= Tavily Keys =========
TAVILY_API_KEYS=tvly-key-1,tvly-key-2,tvly-key-3

# ========= Internal token between MCP and Gateway =========
APP_API_TOKEN=replace-with-a-strong-random-token

# ========= Gateway config =========
REQUEST_TIMEOUT=30
KEY_COOLDOWN_SECONDS=60

# ========= Images =========
DOCKERHUB_USERNAME=yourdockerhubusername
GATEWAY_IMAGE_TAG=latest
MCP_IMAGE_TAG=latest

# ========= Ports =========
GATEWAY_PORT=8080
MCP_PORT=9000
